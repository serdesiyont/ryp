# ── App origin ──────────────────────────────────────────────────────────────
# The Next.js app now hosts both the frontend and the API on the same origin
# (dev server runs on port 4000). Server-side fetches use this base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:4000

# ── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/<ryp-local-db-name>


# ── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key
BETTER_AUTH_URL=http://localhost:4000
BASE_URL=http://localhost:4000
TRUSTED_ORIGINS=http://localhost:4000
VERIFICATION_CALLBACK_URL=http://localhost:4000/
EMAIL_FROM=sendfrom@email.com

# ── Google social login ─────────────────────────────────────────────────────
# NOTE: add http://localhost:4000/api/auth/callback/google as an authorized
# redirect URI in the Google Cloud console.
GOOGLE_CLIENT_ID=your-clientID
GOOGLE_CLIENT_SECRET=your-secret

# ── Gmail API (email verification sender) ───────────────────────────────────
MAIL_GOOGLE_CLIENT_ID=gmail-client-id
MAIL_GOOGLE_CLIENT_SECRET=gmail-client-secret
MAIL_GOOGLE_REFRESH_TOKEN=gmail-token
MAIL_GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground

